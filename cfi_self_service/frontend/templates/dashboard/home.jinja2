{% extends "../layout.jinja2" %}
{% block content %}
  <div class="row">
    <!-- Access Requests -->
    <div class="col-12 mb-5 col-md-6 mb-lg-0 col-lg-4">
      <div class="card shadow h-100">
        <div class="card-body">
          <i class="bi bi-person-fill menu-icon"></i>
          <h5 class="card-title fw-medium mt-3">Access Requests</h5>
          <h6 class="card-subtitle">Here you can make a request for access to an environment.</h6>
          <p>
            <a href="/access_requests/" role="button" class="btn btn-primary mt-4"><i class="bi bi-speedometer2 me-2"></i> Dashboard</a>
            <a href="/access_requests/new/" role="button" class="btn btn-outline-primary mt-4 ms-2"><i class="bi bi-plus-circle me-2"></i> New Request</a>
          </p>
        </div>
      </div>  
    </div>
    <!-- Environment URL's -->
    <div class="col-12 mb-5 col-md-6 mb-lg-0 col-lg-4">
      <div class="card shadow h-100">
        <div class="card-body">
          <i class="bi bi-link-45deg menu-icon"></i>
          <h5 class="card-title fw-medium mt-3">Environment URLs</h5>
          <h6 class="card-subtitle">Here you can generate and use the latest environment URLs.</h6>
          <p><a href="/environment-urls/" role="button" class="btn btn-primary mt-4"><i class="bi bi-link me-2"></i> Generate URLs</a></p>
        </div>
      </div>  
    </div>
    <!-- VPN Profiles -->
    <div class="col-12 col-md-6 col-lg-4">
      <div class="card shadow h-100">
        <div class="card-body">
          <i class="bi bi-lock-fill menu-icon"></i>
          <h5 class="card-title fw-medium mt-3">VPN Profiles</h5>
          <h6 class="card-subtitle">Here you can generate and download the latest VPN profiles.</h6>
          <p><a href="/vpn-profiles/" role="button" class="btn btn-primary mt-4"><i class="bi bi-arrow-right me-2"></i> Download VPN Profiles</a></p>
        </div>
      </div>  
    </div>
  </div>
{% endblock content %}